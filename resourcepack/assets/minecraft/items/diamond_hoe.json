{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "cases": [
      {
        "when": 1001,
        "model": { "type": "minecraft:model", "model": "xdgens:item/hoe_forest" }
      },
      {
        "when": 1002,
        "model": { "type": "minecraft:model", "model": "xdgens:item/hoe_ocean" }
      },
      {
        "when": 1003,
        "model": { "type": "minecraft:model", "model": "xdgens:item/hoe_lava" }
      },
      {
        "when": 1004,
        "model": { "type": "minecraft:model", "model": "xdgens:item/hoe_crystal" }
      },
      {
        "when": 1005,
        "model": { "type": "minecraft:model", "model": "xdgens:item/hoe_shadow" }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "minecraft:item/diamond_hoe"
    }
  }
